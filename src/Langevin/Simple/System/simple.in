# Defining system
units           lj
atom_style     atomic
boundary       p p p
dimension      3  

# Read positions from external file
read_data ../Data/brownian_L_20.0_rho_0.2.data

# System variables
variable seed equal 414543
variable temperature equal 1.0
variable D equal 0.77           #difusion constant
variable gamma equal 1.0/${D}   #translational friction
variable rc equal 1.122462048   #cutoff radius

# Atom types
group dumbbell type 1
mass 1 1.0 

# Define time integration
timestep 0.00001

# Brownian fix
#fix 1 dumbbell brownian ${temperature} ${seed} gamma_t ${gamma} rng gaussian

# Langevin fix
fix 1 all nve
fix 2 all langevin ${T} ${gamma} ${seed} 

# Lennard-Jones interatomic potential
#pair_style lj/cut 2.5
#pair_coeff 1 1 1.0 1.0 ${rc} 

#No interactions
pair_style none 

# MSD
compute msd1 dumbbell msd
variable msd1 equal c_msd1[4]
fix msd1fix dumbbell ave/time 1 1 1  c_msd1[4] file msd_brownian_rho_0.2_3D.data 

thermo_style custom step temp 
thermo 1000

dump 1 dumbbell custom 10000 dump.brownian_rho_0.2_3D id  xu yu zu vx vy vz
#dump_modify sort id

# Run simulation
run 5000000