LAMMPS (23 Jun 2022 - Update 4)
# Defining system
units           lj
atom_style     atomic
boundary       p p p
dimension      2

# Read positions from external file
read_data ../Data/brownian_L_20.0_phi_0.05_2D.data
Reading data file ...
  orthogonal box = (-10 -10 -0.25) to (10 10 0.25)
  3 by 2 by 1 MPI processor grid
  reading atoms ...
  50 atoms
  read_data CPU = 0.002 seconds

# System variables
variable seed equal 414543
variable temperature equal 1.0
variable D equal 1           #difusion constant
variable gamma equal 1.0/${D}   #translational friction
variable gamma equal 1.0/1   
variable rc equal 1.122462048   #cutoff radius

# Atom types
group dumbbell type 1
50 atoms in group dumbbell
mass 1 1.0

# Define time integration
timestep 0.00001

# Brownian fix
fix brownFix dumbbell brownian ${temperature} ${seed} gamma_t ${gamma} rng gaussian
fix brownFix dumbbell brownian 1 ${seed} gamma_t ${gamma} rng gaussian
fix brownFix dumbbell brownian 1 414543 gamma_t ${gamma} rng gaussian
fix brownFix dumbbell brownian 1 414543 gamma_t 1 rng gaussian

# Start with soft potential so particles push apart each other slowly
#pair_style soft ${rc}
#pair_coeff 1 1  100.0 ${rc}

#run 100000

# Switch to Lennard-Jones interatomic potential
#pair_style lj/cut 2.5
#pair_coeff 1 1 1.0 1.0 ${rc}

pair_style none

# MSD
compute msd1 dumbbell msd
variable msd1 equal c_msd1[4]
fix msd1fix dumbbell ave/time 1 1 1  c_msd1[4] file msd_brownian_phi_0.05_2D.data

fix 2d all enforce2d

thermo_style custom step temp
thermo 1000

dump 1 dumbbell custom 10000 dump.brownian_phi_0.05_2D id  xu yu zu vx vy vz

# Run simulation
run 1000000
