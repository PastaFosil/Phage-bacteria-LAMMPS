LAMMPS (23 Jun 2022 - Update 4)
# Defining system
units           lj
atom_style     atomic
boundary       p p p
dimension      3

# Read positions from external file
read_data ../Data/brownian_L_20.0_rho_0.2.data
Reading data file ...
  orthogonal box = (-10 -10 -10) to (10 10 10)
  2 by 1 by 3 MPI processor grid
  reading atoms ...
  3200 atoms
  read_data CPU = 0.005 seconds

# System variables
variable seed equal 414543
variable temperature equal 1.0
variable D equal 0.77           #difusion constant
variable gamma equal 1.0/${D}   #translational friction
variable gamma equal 1.0/0.77   
variable rc equal 1.122462048   #cutoff radius

# Atom types
group dumbbell type 1
3200 atoms in group dumbbell
mass 1 1.0

# Define time integration
timestep 0.00001

# Brownian fix
fix brownFix dumbbell brownian ${temperature} ${seed} gamma_t ${gamma} rng gaussian
fix brownFix dumbbell brownian 1 ${seed} gamma_t ${gamma} rng gaussian
fix brownFix dumbbell brownian 1 414543 gamma_t ${gamma} rng gaussian
fix brownFix dumbbell brownian 1 414543 gamma_t 1.2987012987013 rng gaussian

# Lennard-Jones interatomic potential
pair_style lj/cut 2.5
pair_coeff 1 1 1.0 1.0 ${rc}
pair_coeff 1 1 1.0 1.0 1.122462048

#No interactions
#pair_style none

# MSD
compute msd1 dumbbell msd
variable msd1 equal c_msd1[4]
fix msd1fix dumbbell ave/time 1 1 1  c_msd1[4] file msd_brownian_rho_0.2_3D.data

thermo_style custom step temp
thermo 1000

dump 1 dumbbell custom 10000 dump.brownian_rho_0.2_3D id  xu yu zu vx vy vz
#dump_modify sort id

# Run simulation
run 5000000
